#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// 定义链表结点结构体
typedef struct Node {
    char name[50];      
    float salary;       
    struct Node *next;  // 指向下一个结点的指针
} Node;

// 函数声明
Node* create_list();         // 创建链表
Node* max_list(Node *list);  // 查找最高基本工资的结点
void free_list(Node *list);  // 释放链表内存

int main() {
    Node *list, *max_node;
    
    // 创建链表
    printf("请输入职工信息（输入基本工资为0时结束）：\n");
    list = create_list();
    
    // 查找最高基本工资的职工
    max_node = max_list(list);
    
    // 输出结果
    if (max_node != NULL) {
        printf("\n最高基本工资的职工信息：\n");
        printf("姓名：%s\n", max_node->name);
        printf("基本工资：%.2f\n", max_node->salary);
    } else {
        printf("\n链表为空，没有职工信息。\n");
    }
    
    // 释放链表内存
    free_list(list);
    
    return 0;
}

// 链表
Node* create_list() {
    Node *head = NULL, *tail = NULL, *new_node;
    char name[50];
    float salary;
    
    while (1) {
        printf("请输入姓名：");
        scanf("%s", name);
        printf("请输入基本工资：");
        scanf("%f", &salary);
        
        // 当基本工资为0时结束输入
        if (salary == 0) {
            break;
        }
        
        // 创建新结点
        new_node = (Node*)malloc(sizeof(Node));
        if (new_node == NULL) {
            printf("内存分配失败！\n");
            exit(1);
        }
        
        // 填充结点信息
        strcpy(new_node->name, name);
        new_node->salary = salary;
        new_node->next = NULL;
        
        // 将新结点添加到链表
        if (head == NULL) {
            head = new_node;
            tail = new_node;
        } else {
            tail->next = new_node;
            tail = new_node;
        }
    }
    
    return head;
}

// 查找最高基本工资的结点
Node* max_list(Node *list) {
    if (list == NULL) {
        return NULL;
    }
    
    Node *max_node = list;
    Node *current = list->next;
    
    while (current != NULL) {
        if (current->salary > max_node->salary) {
            max_node = current;
        }
        current = current->next;
    }
    
    return max_node;
}

// 释放链表内存
void free_list(Node *list) {
    Node *temp;
    while (list != NULL) {
        temp = list;
        list = list->next;
        free(temp);
    }
}