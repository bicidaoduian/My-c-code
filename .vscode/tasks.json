{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "编译并运行 C 代码（推荐）",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "cd \"${fileDirname}\" && gcc -Wall -Wextra -std=c99 -mconsole \"${fileBasename}\" -o \"${fileBasenameNoExtension}.exe\" && \"${fileBasenameNoExtension}.exe\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "编译并运行 C 文件"
        },
        {
            "label": "编译 C 代码",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "cd \"${fileDirname}\" && gcc -Wall -Wextra -std=c99 -mconsole \"${fileBasename}\" -o \"${fileBasenameNoExtension}.exe\""
            ],
            "group": {
                "kind": "build"
            },
            "problemMatcher": ["$gcc"],
            "detail": "编译 C 文件"
        },
        {
            "label": "运行 C 代码",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "cd \"${fileDirname}\" && \"${fileBasenameNoExtension}.exe\""
            ],
            "group": {
                "kind": "test"
            },
            "dependsOn": ["编译 C 代码"],
            "detail": "运行编译后的可执行文件"
        }
    ]
}